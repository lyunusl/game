{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": [
      "ES2022"
    ],
    "useDefineForClassFields": false,
    "rootDir": "..",
    "outDir": "dist",
    "experimentalDecorators": true,
    "declaration": true,
    "sourceMap": true
  },
  "include": [
    "src/**/*",
    "../shared/src/**/*"
  ],
  "exclude": [
    "../shared/src/**/*.test.ts"
  ]
}
